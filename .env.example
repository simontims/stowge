# Required
POSTGRES_PASSWORD=change_me
JWT_SECRET=change_me_to_a_long_random_string

# AI providers/models are configured in-app under Settings / AI.
# Add one or more models there after first login.

# Optional: image settings
STORE_ORIGINAL=false
OUTPUT_FORMAT=webp
DISPLAY_MAX_EDGE=2048
DISPLAY_QUALITY=82
THUMB_MAX_EDGE=360
THUMB_QUALITY=70

# Optional: CORS if hosting UI elsewhere (Lovable etc)
# CORS_ORIGINS=https://stowge.mydomain.com
